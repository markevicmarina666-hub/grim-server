<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
<title>Grim Messenger</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
html, body { background: #0b0a0f; color: #d4c5f0; font-family: 'Segoe UI', system-ui, sans-serif; height: 100vh; height: 100dvh; overflow: hidden; position: fixed; width: 100%; }
#app { display: flex; flex-direction: column; height: 100vh; height: 100dvh; max-width: 500px; margin: 0 auto; width: 100%; }
.screen { display: none; flex-direction: column; height: 100%; width: 100%; }
.screen.active { display: flex; }
#login-screen { justify-content: center; align-items: center; gap: 12px; padding: 20px; }
.logo { font-size: 32px; font-weight: bold; color: #9b6dff; margin-bottom: 16px; letter-spacing: 3px; }
input, button { padding: 12px 16px; border-radius: 10px; border: none; font-size: 15px; width: 100%; max-width: 280px; }
input { background: #1a1722; color: #d4c5f0; border: 1px solid #2a2535; }
button { background: #6b3fa0; color: white; cursor: pointer; font-weight: bold; }
button.secondary { background: #1f1b2b; color: #9b6dff; border: 1px solid #3a3050; }
.status { color: #ff6b8a; font-size: 12px; min-height: 18px; text-align: center; }
#header { display: flex; align-items: center; padding: 10px 12px; gap: 8px; border-bottom: 1px solid #1f1b2b; background: #0d0b14; min-height: 48px; flex-shrink: 0; }
#header h2 { flex: 1; font-size: 16px; color: #9b6dff; }
#back-btn, #logout-btn { background: none; border: none; color: #9b6dff; font-size: 18px; cursor: pointer; padding: 5px 8px; }
#chat-list-screen { flex: 1; overflow-y: auto; padding: 8px; }
#new-chat-row { display: flex; gap: 6px; margin-bottom: 8px; }
#new-chat-row input { flex: 1; max-width: none; }
#new-chat-row button { max-width: 70px; font-size: 13px; flex-shrink: 0; }
.chat-item { padding: 12px 14px; margin: 4px 0; background: #13101a; border-radius: 8px; cursor: pointer; border: 1px solid #1f1b2b; font-size: 14px; }
#messages-screen { flex: 1; overflow-y: auto; padding: 8px 10px; display: flex; flex-direction: column; gap: 4px; }
.msg { padding: 8px 12px; border-radius: 12px; max-width: 85%; word-wrap: break-word; font-size: 14px; line-height: 1.3; }
.msg.mine { background: #6b3fa0; align-self: flex-end; }
.msg.other { background: #1a1722; align-self: flex-start; }
.msg .user { font-size: 11px; color: #9b6dff; margin-bottom: 1px; }
.msg .time { font-size: 10px; color: #5a4f6b; margin-top: 3px; text-align: right; }
#input-row { display: flex; gap: 6px; padding: 8px 10px; border-top: 1px solid #1f1b2b; background: #0d0b14; flex-shrink: 0; }
#input-row input { flex: 1; max-width: none; }
#input-row button { max-width: 44px; flex-shrink: 0; font-size: 18px; padding: 10px; }
.hidden { display: none !important; }
</style>
</head>
<body>
<div id="app">
<div id="login-screen" class="screen active">
<div class="logo">GRIM</div>
<input type="text" id="login-username" placeholder="Логин" autocomplete="off">
<input type="password" id="login-password" placeholder="Пароль">
<button onclick="login()">Войти</button>
<button class="secondary" onclick="register()">Регистрация</button>
<div class="status" id="login-status"></div>
</div>
<div id="chat-screen" class="screen">
<div id="header">
<button id="back-btn" class="hidden" onclick="goBack()">←</button>
<h2 id="header-title">Чаты</h2>
<button id="logout-btn" onclick="logout()">🚪</button>
</div>
<div id="chat-list-screen">
<div id="new-chat-row"><input type="text" id="new-chat-name" placeholder="Название чата"><button onclick="createChat()">Создать</button></div>
<div id="chat-list"></div>
</div>
<div id="messages-screen" class="hidden"></div>
<div id="input-row" class="hidden"><input type="text" id="message-input" placeholder="Сообщение..."><button onclick="sendMessage()">→</button></div>
</div>
</div>
<script>
const API = 'wss://grim-server-kfx7.onrender.com/ws';
let ws = null, currentUser = null, currentChat = null;

function login() {
    const u = document.getElementById('login-username').value.trim();
    const p = document.getElementById('login-password').value.trim();
    if (!u || !p) return;
    const ws2 = new WebSocket(API);
    ws2.onopen = () => ws2.send(JSON.stringify({action: 'login', username: u, password: p}));
    ws2.onmessage = (e) => {
        const d = JSON.parse(e.data);
        if (d.status === 'ok') { currentUser = d.username; ws = ws2; setupWS(); showScreen('chat-screen'); loadChats(); }
        else { document.getElementById('login-status').textContent = d.message || 'Ошибка'; ws2.close(); }
    };
    ws2.onerror = () => document.getElementById('login-status').textContent = 'Нет соединения';
}

function register() {
    const u = document.getElementById('login-username').value.trim();
    const p = document.getElementById('login-password').value.trim();
    if (!u || !p) return;
    const ws2 = new WebSocket(API);
    ws2.onopen = () => ws2.send(JSON.stringify({action: 'register', username: u, password: p}));
    ws2.onmessage = (e) => {
        const d = JSON.parse(e.data);
        document.getElementById('login-status').textContent = d.message || (d.status === 'ok' ? 'Успешно! Войдите.' : 'Ошибка');
        ws2.close();
    };
    ws2.onerror = () => document.getElementById('login-status').textContent = 'Нет соединения';
}

function setupWS() {
    ws.onmessage = (e) => {
        const data = JSON.parse(e.data);
        if (data.action === 'new_message' && data.chat_id === currentChat) addMessage(data.username, data.content, data.username === currentUser);
        if (data.status === 'ok' && data.chats) renderChats(data.chats);
        if (data.status === 'ok' && data.messages) renderMessages(data.messages);
        if (data.status === 'ok' && data.chat_id) { loadChats(); openChat(data.chat_id, data.name || 'Чат'); }
    };
    ws.onclose = () => alert('Соединение потеряно');
}

function showScreen(id) { document.querySelectorAll('.screen').forEach(s => s.classList.remove('active')); document.getElementById(id).classList.add('active'); }
function loadChats() { if (ws && ws.readyState === 1) ws.send(JSON.stringify({action: 'get_chats'})); }
function renderChats(chats) { document.getElementById('chat-list').innerHTML = chats.map(c => `<div class="chat-item" onclick="openChat(${c.id}, '${c.name.replace(/'/g, "\\'")}')"># ${c.name}</div>`).join(''); }
function createChat() { const name = document.getElementById('new-chat-name').value.trim(); if (!name || !ws) return; ws.send(JSON.stringify({action: 'create_chat', name: name})); document.getElementById('new-chat-name').value = ''; }
function openChat(id, name) { currentChat = id; document.getElementById('header-title').textContent = '#' + name; document.getElementById('back-btn').classList.remove('hidden'); document.getElementById('chat-list-screen').classList.add('hidden'); document.getElementById('messages-screen').classList.remove('hidden'); document.getElementById('input-row').classList.remove('hidden'); document.getElementById('messages-screen').innerHTML = ''; ws.send(JSON.stringify({action: 'get_history', chat_id: id})); }
function goBack() { currentChat = null; document.getElementById('header-title').textContent = 'Чаты'; document.getElementById('back-btn').classList.add('hidden'); document.getElementById('chat-list-screen').classList.remove('hidden'); document.getElementById('messages-screen').classList.add('hidden'); document.getElementById('input-row').classList.add('hidden'); loadChats(); }
function sendMessage() { const input = document.getElementById('message-input'); const content = input.value.trim(); if (!content || !currentChat || !ws) return; ws.send(JSON.stringify({action: 'send_message', chat_id: currentChat, content: content})); addMessage(currentUser, content, true); input.value = ''; }
function addMessage(username, text, isMine) { const div = document.getElementById('messages-screen'); const now = new Date(); const time = now.getHours().toString().padStart(2,'0') + ':' + now.getMinutes().toString().padStart(2,'0'); div.innerHTML += `<div class="msg ${isMine ? 'mine' : 'other'}">${isMine ? '' : `<div class="user">${username}</div>`}<div>${text}</div><div class="time">${time}</div></div>`; div.scrollTop = div.scrollHeight; }
function renderMessages(msgs) { document.getElementById('messages-screen').innerHTML = ''; msgs.forEach(m => addMessage(m.username, m.content, m.username === currentUser)); }
function logout() { if (ws) ws.close(); ws = null; currentUser = null; currentChat = null; showScreen('login-screen'); }
</script>
</body>
</html>
